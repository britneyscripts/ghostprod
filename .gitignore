# ============================================
# ghostprod — .gitignore
# ============================================

# ⚠️  NUNCA commitar arquivos de ambiente
.env
.env.local
.env.production
.env.*.local

# ============================================
# Python (backend)
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json

# Playwright browsers
/playwright-browsers/

# spaCy models (grandes demais para o repo)
*.whl

# ============================================
# Node / Frontend
# ============================================
node_modules/
.npm
.yarn/
*.tgz

# Next.js / React build
.next/
out/
build/
dist/

# ============================================
# Firebase
# ============================================
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
# NÃO ignorar firebase-blueprint.json (é documentação)

# ============================================
# IDEs e editores
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# Logs
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Docker
# ============================================
.dockerignore
# NÃO ignorar Dockerfile (necessário para Cloud Run)

# ============================================
# Dados de pesquisa (sensível)
# ============================================
data/raw/
data/outputs/
*.csv
# exceto arquivos de exemplo
!data/examples/*.csv

# ============================================
# Chaves e credenciais
# ============================================
*.pem
*.key
*.p12
service-account*.json
gcp-credentials*.json
