# ============================================
# ghostprod — .env.example
# ============================================
# Copie este arquivo para .env e preencha com
# seus valores reais. NUNCA commite o .env.
# ============================================

# --------------------------------------------
# Claude API (Agente 4 — Gap Analysis)
# Obter em: https://console.anthropic.com
# --------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-SUBSTITUA-PELA-SUA-CHAVE

# --------------------------------------------
# CrUX API (Agente 1 — Performance)
# Opcional: sem chave funciona com quota menor
# Obter em: https://developers.google.com/speed/docs/insights/v5/get-started
# --------------------------------------------
CRUX_API_KEY=AIzaSy-SUBSTITUA-PELA-SUA-CHAVE

# --------------------------------------------
# Rate limiting
# --------------------------------------------
RATE_LIMIT_PER_IP=10          # análises por IP por dia
RATE_LIMIT_MONTHLY=500        # total mensal (hard limit)

# --------------------------------------------
# CORS — origens permitidas
# --------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,https://ghostprod.io

# --------------------------------------------
# Ambiente
# --------------------------------------------
ENVIRONMENT=development       # development | production

# --------------------------------------------
# Firebase (frontend) — salvar como .env.local
# Obter em: Firebase Console → Configurações do projeto
# --------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSy-SUBSTITUA
VITE_FIREBASE_AUTH_DOMAIN=ghostprod-SUBSTITUA.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ghostprod-SUBSTITUA
VITE_FIREBASE_STORAGE_BUCKET=ghostprod-SUBSTITUA.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:SUBSTITUA

# URL do backend
VITE_API_URL=http://localhost:8000